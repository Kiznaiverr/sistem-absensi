{
  "name": "absensi-system",
  "version": "1.0.0",
  "description": "RFID-based attendance system for Madrasah",
  "type": "module",
  "main": "dist/backend/app.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:server\"",
    "dev:vite": "vite",
    "dev:server": "tsx watch src/backend/app.ts",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "node dist/backend/app.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "rfid",
    "attendance",
    "madrasah"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.1",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "tsx": "^4.1.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  }
}
