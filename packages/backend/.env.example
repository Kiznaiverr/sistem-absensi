# Environment Configuration
NODE_ENV=development

# Server Configuration
SERVER_PORT=5000
SERVER_HOST=0.0.0.0

# Supabase Configuration
# SUPABASE_SECRET_KEY is required for backend database access (admin operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sbsk_your-secret-key-here

# JWT Authentication
# Generate strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-minimum-32-characters-long

# Token Expiry Times (in seconds)
# ACCESS_TOKEN_EXPIRES_IN: 43200 = 12 hours
# REFRESH_TOKEN_EXPIRES_IN: 604800 = 7 days
ACCESS_TOKEN_EXPIRES_IN=43200
REFRESH_TOKEN_EXPIRES_IN=604800

# CORS Configuration
# Frontend URL for cross-origin requests
# Multiple URLs can be comma-separated: http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Timezone
TIMEZONE=Asia/Jakarta

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_SANTRI=43200
CACHE_TTL_ATTENDANCE=300

# Attendance Shift Times (24-hour format)
SHIFT_SIANG_START=13:00
SHIFT_SIANG_END=16:00
SHIFT_MALAM_START=18:00
SHIFT_MALAM_END=21:00

# Email/SMTP Configuration (Archive Job Notifications)
# Using Gmail? Create App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_EMAIL=noreply@absensi-system.com
ALERT_EMAIL=admin@example.com

# Cloudflare Tunnel (Optional - VPS with NAT Only)
# Required only when using Cloudflare Tunnel for VPS behind NAT
# Setup: https://dash.cloudflare.com/ → Zero Trust → Tunnels
# Leave empty or remove if using localhost
CLOUDFLARE_TOKEN=
